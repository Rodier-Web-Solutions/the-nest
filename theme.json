{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": true,
			"customDuplicate": false,
			"customGradient": false,
			"defaultPalette": false,
			"defaultGradients": false,
			"duotone": [],
			"palette": [
				{ "slug": "primary",        "color": "#2563eb", "name": "Primary" },
				{ "slug": "accent",         "color": "#14b8a6", "name": "Accent" },
				{ "slug": "neutral-dark",   "color": "#111827", "name": "Neutral Dark" },
				{ "slug": "neutral-medium", "color": "#374151", "name": "Neutral Medium" },
				{ "slug": "background",     "color": "#f9fafb", "name": "Background" },
				{ "slug": "surface",        "color": "#ffffff", "name": "Surface" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Plus Jakarta Sans', sans-serif",
					"name": "Plus Jakarta Sans",
					"slug": "heading"
				},
				{
					"fontFamily": "'Inter', sans-serif",
					"name": "Inter",
					"slug": "body"
				},
				{
					"fontFamily": "ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace",
					"name": "Monospace",
					"slug": "mono"
				}
			],
			"fontSizes": [
				{ "slug": "sm",   "size": "0.875rem", "name": "SM"  },
				{ "slug": "md",   "size": "1rem",     "name": "MD"  },
				{ "slug": "lg",   "size": "1.125rem", "name": "LG"  },
				{ "slug": "xl",   "size": "1.25rem",  "name": "XL"  },
				{ "slug": "xl-2", "size": "1.5rem",   "name": "2XL" },
				{ "slug": "xl-3", "size": "1.875rem", "name": "3XL" },
				{ "slug": "xl-4", "size": "2.25rem",  "name": "4XL" },
				{ "slug": "xl-5", "size": "3rem",     "name": "5XL" },
				{ "slug": "xl-6", "size": "3.75rem",  "name": "6XL" }
			]
		},
		"spacing": {
			"padding": true,
			"margin": true,
			"blockGap": true,
			"units": [ "px", "em", "rem", "vh", "vw", "%" ],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "xxs",  "size": "0.25rem", "name": "2XS" },
				{ "slug": "xs",   "size": "0.5rem",  "name": "XS"  },
				{ "slug": "sm",   "size": "0.75rem", "name": "SM"  },
				{ "slug": "md",   "size": "1rem",    "name": "MD"  },
				{ "slug": "lg",   "size": "1.5rem",  "name": "LG"  },
				{ "slug": "xl",   "size": "2rem",    "name": "XL"  },
				{ "slug": "xl-2", "size": "3rem",    "name": "2XL" },
				{ "slug": "xl-3", "size": "4rem",    "name": "3XL" },
				{ "slug": "xl-4", "size": "6rem",    "name": "4XL" },
				{ "slug": "xl-5", "size": "8rem",    "name": "5XL" }
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1200px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"presets": [
				{ "slug": "sm", "name": "Small",  "shadow": "0 1px 2px 0 rgba(0,0,0,0.05)" },
				{ "slug": "md", "name": "Medium", "shadow": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)" },
				{ "slug": "lg", "name": "Large",  "shadow": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)" }
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--neutral-medium)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "0",
			"padding": {
				"left": "var(--wp--preset--spacing--xl)",
				"right": "var(--wp--preset--spacing--xl)"
			}
		},
		"elements": {
			"h1": {
				"color": { "text": "var(--wp--preset--color--neutral-dark)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xl-6)",
					"fontWeight": "800",
					"lineHeight": "1.05",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"color": { "text": "var(--wp--preset--color--neutral-dark)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xl-5)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"color": { "text": "var(--wp--preset--color--neutral-dark)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xl-4)",
					"fontWeight": "700",
					"lineHeight": "1.2",
					"letterSpacing": "-0.015em"
				}
			},
			"h4": {
				"color": { "text": "var(--wp--preset--color--neutral-dark)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xl-3)",
					"fontWeight": "600",
					"lineHeight": "1.3",
					"letterSpacing": "-0.01em"
				}
			},
			"h5": {
				"color": { "text": "var(--wp--preset--color--neutral-dark)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xl-2)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"color": { "text": "var(--wp--preset--color--neutral-dark)" },
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--xl)",
					"fontWeight": "600",
					"lineHeight": "1.5",
					"letterSpacing": "0.01em"
				}
			},
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" },
				":hover": {
					"color": { "text": "var(--wp--preset--color--accent)" }
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--surface)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--md)"
				},
				"border": { "radius": "0.375rem" },
				":hover": {
					"color": { "background": "var(--wp--preset--color--accent)" }
				}
			}
		}
	}
}
